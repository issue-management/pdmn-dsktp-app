# GitHub App credentials
GITHUB_APP_ID=your-app-id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Server port (optional, defaults to 3000)
PORT=4888

# For local development, use smee.io to forward webhooks:
# 1. Go to https://smee.io/new to get a webhook proxy URL
# 2. Set that URL as the webhook URL in your GitHub App settings
# 3. Run: smee -u https://smee.io/YOUR_CHANNEL -t http://localhost:4888/api/github/webhooks
