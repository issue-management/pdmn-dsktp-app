[
  {
    "repository": "*",
    "mappings": [
      { "pattern": "eslint.config.mjs", "domain": "Foundations" },
      { "pattern": "**/tsconfig.json", "domain": "Foundations" }
    ],
    "globalMappings": [{ "pattern": "tests/**", "domain": "QE" }]
  },
  {
    "repository": "https://github.com/podman-desktop/podman-desktop",
